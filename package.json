{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "betterstack-utils",
  "title": "BetterStack Utils",
  "description": "View your BetterStack Primary on-call schedule",
  "icon": "extension-icon.png",
  "author": "doktor500",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "on-call-schedule",
      "title": "On Call Schedule",
      "description": "Shows a 3-month on-call grid for the Primary schedule",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiToken",
      "title": "API Token",
      "description": "Your BetterStack API token",
      "type": "password",
      "required": true
    },
    {
      "name": "teamId",
      "title": "Team Id",
      "description": "Your BetterStack team Id. Find it in the URL when viewing your on-call schedule: uptime.betterstack.com/team/t{id}/oncalls",
      "type": "textfield",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.18",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "luxon": "^3.7.2",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.6.0",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "~25.9.1",
    "@types/react": "~19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish",
    "ts:check": "tsc --noEmit"
  }
}
